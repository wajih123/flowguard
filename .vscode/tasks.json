{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Docker Up",
      "type": "shell",
      "command": "docker-compose up -d",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "flowguard"
      },
      "problemMatcher": []
    },
    {
      "label": "Quarkus Dev",
      "type": "shell",
      "command": "./mvnw quarkus:dev -Ddebug",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "flowguard"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "ML Service",
      "type": "shell",
      "command": "uvicorn main:app --reload --port 8001",
      "options": { "cwd": "${workspaceFolder}/ml-service" },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "flowguard"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "React Native",
      "type": "shell",
      "command": "npx expo start",
      "options": { "cwd": "${workspaceFolder}/mobile" },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "flowguard"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Start FlowGuard",
      "dependsOn": ["Docker Up", "Quarkus Dev", "ML Service", "React Native"],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Type Check",
      "type": "shell",
      "command": "tsc --noEmit",
      "options": { "cwd": "${workspaceFolder}/mobile" },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "flowguard"
      },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "Lint",
      "type": "shell",
      "command": "eslint src --ext .ts,.tsx",
      "options": { "cwd": "${workspaceFolder}/mobile" },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "flowguard"
      },
      "problemMatcher": ["$eslint-stylish"]
    }
  ]
}
