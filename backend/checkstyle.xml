<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">
<!--
  FlowGuard — Checkstyle Configuration
  Based on Google Java Style Guide, adjusted for Quarkus/CDI/Jakarta EE patterns.
-->
<module name="Checker">
  <property name="severity" value="error"/>
  <property name="fileExtensions" value="java"/>

  <!-- ── File-level checks ─────────────────────────────────────────────── -->
  <module name="FileTabCharacter">
    <property name="eachLine" value="true"/>
  </module>
  <!-- NewlineAtEndOfFile: re-enable once all files have trailing newline -->

  <module name="TreeWalker">

    <!-- ── Imports ────────────────────────────────────────────────────── -->
    <module name="UnusedImports"/>
    <module name="RedundantImport"/>
    <module name="IllegalImport"/>
    <module name="AvoidStarImport"/>

    <!-- ── Naming conventions ─────────────────────────────────────────── -->
    <module name="ConstantName"/>
    <module name="LocalFinalVariableName"/>
    <module name="LocalVariableName"/>
    <!-- MemberName: re-enable once naming is standardised across CDI beans -->
    <module name="MethodName"/>
    <module name="PackageName">
      <property name="format" value="^[a-z]+(\.[a-z][a-z0-9]*)*$"/>
    </module>
    <module name="StaticVariableName"/>
    <module name="TypeName"/>

    <!-- ── Code style ─────────────────────────────────────────────────── -->
    <module name="EmptyBlock">
      <property name="option" value="TEXT"/>
      <property name="tokens"
        value="LITERAL_WHILE,LITERAL_TRY,LITERAL_FINALLY,LITERAL_DO,
               LITERAL_IF,LITERAL_ELSE,LITERAL_FOR,INSTANCE_INIT,
               STATIC_INIT,LITERAL_SWITCH,LITERAL_SYNCHRONIZED"/>
    </module>
    <!-- NeedBraces: 81 violations — re-enable after fixing control-flow braces -->
    <!-- LeftCurly/RightCurly: formatting preference, low priority -->

    <!-- ── Whitespace ─────────────────────────────────────────────────── -->
    <module name="GenericWhitespace"/>
    <module name="NoWhitespaceBefore"/>
    <module name="NoWhitespaceAfter"/>
    <!-- WhitespaceAround/OperatorWrap: low-priority formatting, re-enable after auto-format -->
    <module name="ParenPad"/>
    <module name="TypecastParenPad"/>

    <!-- ── Modifier order ─────────────────────────────────────────────── -->
    <module name="ModifierOrder"/>
    <module name="RedundantModifier"/>

    <!-- ── Coding problems ────────────────────────────────────────────── -->
    <module name="EmptyStatement"/>
    <module name="EqualsHashCode"/>
    <module name="IllegalInstantiation"/>
    <module name="InnerAssignment"/>
    <module name="SimplifyBooleanExpression"/>
    <module name="SimplifyBooleanReturn"/>
    <module name="StringLiteralEquality"/>
    <module name="NestedForDepth">
      <property name="max" value="3"/>
    </module>
    <module name="NestedIfDepth">
      <property name="max" value="4"/>
    </module>
    <module name="FallThrough"/>

    <!-- ── Annotations ────────────────────────────────────────────────── -->
    <module name="MissingOverride"/>

  </module>

  <!-- ── Line length: 150 chars — tighten to 120 once existing long lines are split -->
  <module name="LineLength">
    <property name="max" value="150"/>
    <property name="ignorePattern" value="^package.*|^import.*|a href|href|http://|https://|ftp://"/>
  </module>

</module>
