{
  "id": null,
  "uid": "flowguard-overview",
  "title": "FlowGuard — Production Overview",
  "tags": ["flowguard", "production"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "panels": [
    {
      "type": "row",
      "id": 1,
      "title": "Service Health",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "type": "stat",
      "id": 2,
      "title": "Backend",
      "description": "Quarkus API — SmallRye Health",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "up{job=\"flowguard-backend\"}",
          "legendFormat": "backend",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP", "color": "green" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "red" },
              { "value": 1, "color": "green" }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },

    {
      "type": "stat",
      "id": 3,
      "title": "Frontend",
      "description": "HTTP probe via Blackbox Exporter",
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 4 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "probe_success{instance=\"http://frontend:8080/\"}",
          "legendFormat": "frontend",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP", "color": "green" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "red" },
              { "value": 1, "color": "green" }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },

    {
      "type": "stat",
      "id": 4,
      "title": "PostgreSQL",
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 4 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "up{job=\"postgres\"}",
          "legendFormat": "postgres",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP", "color": "green" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "red" },
              { "value": 1, "color": "green" }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },

    {
      "type": "stat",
      "id": 5,
      "title": "Redis",
      "gridPos": { "x": 12, "y": 1, "w": 4, "h": 4 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "up{job=\"redis\"}",
          "legendFormat": "redis",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP", "color": "green" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "red" },
              { "value": 1, "color": "green" }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },

    {
      "type": "stat",
      "id": 6,
      "title": "ML Service",
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 4 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "up{job=\"flowguard-ml-service\"}",
          "legendFormat": "ml-service",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP", "color": "green" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "red" },
              { "value": 1, "color": "green" }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },

    {
      "type": "stat",
      "id": 7,
      "title": "Active Alerts",
      "gridPos": { "x": 20, "y": 1, "w": 4, "h": 4 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "count(ALERTS{alertstate=\"firing\"}) OR vector(0)",
          "legendFormat": "firing",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 1, "color": "red" }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },

    {
      "type": "row",
      "id": 10,
      "title": "API Traffic",
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "type": "timeseries",
      "id": 11,
      "title": "Request Rate (req/s)",
      "gridPos": { "x": 0, "y": 6, "w": 8, "h": 8 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"flowguard-backend\"}[5m]))",
          "legendFormat": "total req/s",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"flowguard-backend\", status=~\"2..\"}[5m]))",
          "legendFormat": "2xx req/s",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": { "tooltip": { "mode": "multi" } }
    },

    {
      "type": "timeseries",
      "id": 12,
      "title": "5xx Error Rate",
      "gridPos": { "x": 8, "y": 6, "w": 8, "h": 8 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"flowguard-backend\", status=~\"5..\"}[5m]))",
          "legendFormat": "5xx/s",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"flowguard-backend\", status=~\"4..\"}[5m]))",
          "legendFormat": "4xx/s",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "thresholdsStyle": { "mode": "area" } },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 0.1, "color": "red" }
            ]
          }
        }
      }
    },

    {
      "type": "timeseries",
      "id": 13,
      "title": "Response Time p95 (s)",
      "gridPos": { "x": 16, "y": 6, "w": 8, "h": 8 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"flowguard-backend\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{job=\"flowguard-backend\"}[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 3, "color": "red" }
            ]
          }
        }
      }
    },

    {
      "type": "row",
      "id": 20,
      "title": "Infrastructure",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "type": "timeseries",
      "id": 21,
      "title": "Host CPU Usage (%)",
      "gridPos": { "x": 0, "y": 15, "w": 8, "h": 8 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 80, "color": "yellow" },
              { "value": 90, "color": "red" }
            ]
          }
        }
      }
    },

    {
      "type": "timeseries",
      "id": 22,
      "title": "Host Memory Usage (%)",
      "gridPos": { "x": 8, "y": 15, "w": 8, "h": 8 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "(node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / node_memory_MemTotal_bytes * 100",
          "legendFormat": "Memory %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 80, "color": "yellow" },
              { "value": 90, "color": "red" }
            ]
          }
        }
      }
    },

    {
      "type": "timeseries",
      "id": 23,
      "title": "JVM Heap Usage (%)",
      "gridPos": { "x": 16, "y": 15, "w": 8, "h": 8 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\", job=\"flowguard-backend\"} / jvm_memory_max_bytes{area=\"heap\", job=\"flowguard-backend\"} * 100",
          "legendFormat": "JVM Heap %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 75, "color": "yellow" },
              { "value": 90, "color": "red" }
            ]
          }
        }
      }
    },

    {
      "type": "row",
      "id": 30,
      "title": "Containers & Database",
      "gridPos": { "x": 0, "y": 23, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "type": "timeseries",
      "id": 31,
      "title": "Container CPU Usage (%)",
      "description": "Per-container CPU usage from cAdvisor",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name=~\"flowguard-.*\", name!=\"\"}[5m])) * 100",
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "palette-classic" }
        }
      }
    },

    {
      "type": "timeseries",
      "id": 32,
      "title": "Container Memory Usage (MB)",
      "description": "Per-container RSS memory from cAdvisor",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "sum by (name) (container_memory_rss{name=~\"flowguard-.*\", name!=\"\"}) / 1024 / 1024",
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "MB", "color": { "mode": "palette-classic" } }
      }
    },

    {
      "type": "timeseries",
      "id": 33,
      "title": "PostgreSQL Active Connections",
      "gridPos": { "x": 0, "y": 32, "w": 8, "h": 7 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "pg_stat_activity_count{job=\"postgres\"}",
          "legendFormat": "connections",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 150, "color": "yellow" },
              { "value": 180, "color": "red" }
            ]
          }
        }
      }
    },

    {
      "type": "timeseries",
      "id": 34,
      "title": "Nginx Requests/s",
      "gridPos": { "x": 8, "y": 32, "w": 8, "h": 7 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "rate(nginx_http_requests_total{job=\"nginx\"}[5m])",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      }
    },

    {
      "type": "timeseries",
      "id": 35,
      "title": "Host Disk Usage (%)",
      "gridPos": { "x": 16, "y": 32, "w": 8, "h": 7 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "(1 - node_filesystem_avail_bytes{mountpoint=\"/\", job=\"node\"} / node_filesystem_size_bytes{mountpoint=\"/\", job=\"node\"}) * 100",
          "legendFormat": "disk %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 80, "color": "yellow" },
              { "value": 90, "color": "red" }
            ]
          }
        }
      }
    }
  ]
}
