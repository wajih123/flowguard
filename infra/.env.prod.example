# ─────────────────────────────────────────────────────────────────────────────
# FlowGuard — Production Environment Variables
# Copy to .env.prod and fill in secrets.
# NEVER commit .env.prod to git (it's in .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=flowguard
POSTGRES_USER=flowguard
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── Bridge API (banking aggregation) ─────────────────────────────────────────
# Sandbox (test):  already populated in application.properties
# Production: get from https://dashboard.bridgeapi.io → Settings → API Keys
BRIDGE_CLIENT_ID=YOUR_BRIDGE_CLIENT_ID
BRIDGE_CLIENT_SECRET=YOUR_BRIDGE_CLIENT_SECRET
BRIDGE_REDIRECT_URL=http://157.180.43.233/banking/callback

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# Phase 1 (HTTP/IP): http://157.180.43.233
# Phase 2 (HTTPS/domain): https://flowguard.fr,https://www.flowguard.fr
CORS_ORIGINS=http://157.180.43.233

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_IP=157.180.43.233
DOMAIN=flowguard.fr
