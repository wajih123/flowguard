# ─────────────────────────────────────────────────────────────────────────────
# FlowGuard — Production Environment Variables
# Copy to .env.prod and fill in secrets.
# NEVER commit .env.prod to git (it's in .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=flowguard
POSTGRES_USER=flowguard
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── Bridge API (banking aggregation) ─────────────────────────────────────────
# Sandbox (test):  already populated in application.properties
# Production: get from https://dashboard.bridgeapi.io → Settings → API Keys
BRIDGE_CLIENT_ID=YOUR_BRIDGE_CLIENT_ID
BRIDGE_CLIENT_SECRET=YOUR_BRIDGE_CLIENT_SECRET
BRIDGE_REDIRECT_URL=https://157-180-43-233.sslip.io/banking/callback

# ── CORS ──────────────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://157-180-43-233.sslip.io

# ── SMTP (Email OTP / 2FA) ───────────────────────────────────────────────────────────
# Any STARTTLS provider works: Mailjet, OVH, Brevo, SendGrid, etc.
# Example below uses Mailjet (port 587 + STARTTLS).
# Mailjet: https://app.mailjet.com → Account → API Keys → SMTP Settings
# Gmail (free, no extra account needed):
#   - Enable 2FA on your Google account: https://myaccount.google.com/security
#   - Generate an App Password: https://myaccount.google.com/apppasswords
#     (select "Other" app, name it "FlowGuard", copy the 16-char password)
#   SMTP_HOST=smtp.gmail.com
#   SMTP_USER=youraddress@gmail.com
#   SMTP_PASSWORD=xxxx xxxx xxxx xxxx   <-- 16-char app password (spaces ok)
#
# Mailjet (French, 6 000 emails/day free — https://app.mailjet.com):
#   SMTP_HOST=in-v3.mailjet.com
#   SMTP_USER=YOUR_MAILJET_API_KEY  SMTP_PASSWORD=YOUR_MAILJET_SECRET_KEY
#
# Brevo/Sendinblue (French, 300/day free):
#   SMTP_HOST=smtp-relay.brevo.com
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=YOUR_GMAIL_ADDRESS@gmail.com
SMTP_PASSWORD=YOUR_16_CHAR_APP_PASSWORD

# ── Server ───────────────────────────────────────────────────────────────────────────
SERVER_IP=157.180.43.233
DOMAIN=flowguard.fr
